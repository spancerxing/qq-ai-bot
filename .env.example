# QQ Bot
QQ_APP_ID=your_app_id
QQ_APP_SECRET=your_app_secret

# AI - OpenAI compatible (supports DeepSeek, Qwen, etc. via base_url)
AI_OPENAI_KEYS=sk-key1,sk-key2
AI_OPENAI_BASE_URL=https://api.openai.com/v1

# AI - Google Gemini (official SDK)
AI_GEMINI_KEYS=AIzaSy-key1,AIzaSy-key2
# Custom base URL for Gemini (only needed if using a Gemini-protocol proxy)
# AI_GEMINI_BASE_URL=https://your-proxy.example.com/v1beta

# AI - Anthropic Claude
AI_CLAUDE_KEYS=sk-ant-key1,sk-ant-key2

# Default model (prefix determines provider: gpt-*, gemini-*, claude-*, deepseek-*)
AI_DEFAULT_MODEL=gpt-4o-mini

# System prompt for AI (leave empty to use default)
AI_SYSTEM_PROMPT="你是一个友好、有用的AI助手。请用简洁的中文回答。"

# AI generation parameters
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_PRESENCE_PENALTY=0.0

# Multi-line system prompt example (use \n inside quotes):
# AI_SYSTEM_PROMPT="第一行\n第二行\n第三行"

# Session
SESSION_TIMEOUT=30
SESSION_MAX_HISTORY=10
SESSIONS_DIR=sessions

# MCP (Model Context Protocol) servers
# Format: JSON array with server configurations
# Types: "sse" (server-sent events), "streamable_http", "stdio" (local process)
#
# Examples:
#   Firecrawl MCP (free tier, no API key):
#     MCP_SERVERS=[{"type":"streamable_http","url":"https://mcp.firecrawl.dev/v2/mcp"}]
#
#   Firecrawl MCP (with API key for higher limits, requires Firecrawl account):
#     MCP_SERVERS=[{"type":"streamable_http","url":"https://mcp.firecrawl.dev/YOUR_API_KEY/v2/mcp"}]
#
#   Local stdio server:
#     MCP_SERVERS=[{"type":"stdio","command":"python","args":["/path/to/server.py"]}]
#
#   Local SSE server:
#     MCP_SERVERS=[{"type":"sse","url":"http://localhost:3000/sse"}]
#
#   Multiple servers:
#     MCP_SERVERS=[{"type":"streamable_http","url":"https://mcp.firecrawl.dev/v2/mcp"},{"type":"stdio","command":"node","args":["server.js"]}]
MCP_SERVERS=[]

# Server
HOST=0.0.0.0
PORT=8000
